{
  "name": "super-light-web-whatsapp-api-server",
  "version": "1.1.2",
  "description": "A super lightweight web server for WhatsApp API using @whiskeysockets/baileys",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "nodemon index.js",
    "test": "jest",
    "install:smart": "node install-dependencies.js",
    "start-production": "npm run start:prod",
    "start:prod:unix": "bash start-production.sh",
    "start:prod:windows": "start-production.bat",
    "start:prod": "node -r dotenv/config index.js",
    "fix:sqlite": "node fix-sqlite3.js",
    "setup:storage": "node scripts/setup-storage.js",
    "check:production": "node scripts/check-production.js",
    "media-handoff:health": "node scripts/media-handoff-health.js",
    "media-handoff:retry-failed": "node scripts/media-handoff-retry-failed.js",
    "media-handoff:redispatch": "node scripts/media-handoff-redispatch.js",
    "media-handoff:cleanup": "node scripts/media-handoff-cleanup.js",
    "history-sync:health": "node scripts/history-sync-health.js",
    "history-sync:retry-failed": "node scripts/history-sync-retry-failed.js",
    "history-sync:cleanup": "node scripts/history-sync-cleanup.js",
    "history-sync:process-once": "node scripts/history-sync-process-once.js",
    "postinstall": "npm run fix:sqlite || true"
  },
  "author": "Alucard0x1",
  "license": "MIT",
  "dependencies": {
    "@hapi/boom": "^10.0.1",
    "@whiskeysockets/baileys": "^7.0.0-rc11",
    "axios": "^1.13.5",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^12.5.0",
    "body-parser": "^1.20.4",
    "csv-parse": "^5.6.0",
    "date-fns": "^2.30.0",
    "dotenv": "^16.6.1",
    "express": "^4.22.0",
    "express-rate-limit": "^7.5.0",
    "express-session": "^1.18.2",
    "helmet": "^8.0.0",
    "multer": "^2.0.0",
    "pino": "^9.5.0",
    "sanitize-html": "^2.17.0",
    "session-file-store": "^1.5.0",
    "supertest": "^7.2.2",
    "uuid": "^14.0.0",
    "validator": "^13.15.22",
    "ws": "^8.18.3"
  },
  "optionalDependencies": {
    "bcrypt": "^6.0.0"
  },
  "devDependencies": {
    "axios-cookiejar-support": "^6.0.5",
    "jest": "^29.7.0",
    "nodemon": "^3.1.9",
    "qrcode-terminal": "^0.12.0",
    "tough-cookie": "^6.0.0"
  }
}
