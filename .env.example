# ==========================================
# HAXIS WhatsApp Web Engine Configuration
# ==========================================

# Server configuration
PORT=3000
NODE_ENV=production
APP_BASE_PATH=/home/usebws/api
ENGINE_PUBLIC_URL=https://api.useb.ws

# ==========================================
# Identificação da Instância (HAXIS APIH)
# ==========================================
# APIWS_ENGINE_ID: Identificador único da instalação da apiWS (Recomendado: domínio público)
# APIWS_PUBLIC_URL: URL pública/base da instalação (Opcional, mas recomendado)
APIWS_ENGINE_ID=apiws.hartmidia.com
APIWS_PUBLIC_URL=https://apiws.hartmidia.com

# ==========================================
# Security & Authentication
# ==========================================
ADMIN_DASHBOARD_PASSWORD=your_secure_password_here
MASTER_API_KEY=your_master_api_key_here
TOKEN_ENCRYPTION_KEY=your_64_char_hex_encryption_key_here
SESSION_SECRET=your_express_session_secret_here

# ==========================================
# Webhooks (HAXIS Integration)
# ==========================================
WEBHOOK_URL=https://api.hartmidia.com/engine-webhook
WEBHOOK_SECRET=your_webhook_secret_here
WEBHOOK_TIMEOUT_MS=5000

# ==========================================
# Rate Limiting
# ==========================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=300
SEND_RATE_LIMIT_WINDOW_MS=60000
SEND_RATE_LIMIT_MAX_REQUESTS=60
ADMIN_RATE_LIMIT_WINDOW_MS=900000
ADMIN_RATE_LIMIT_MAX_REQUESTS=100

# ==========================================
# Paths seguros fora do public_html
# ==========================================
DATA_PATH=/home/usebws/apiws-data
AUTH_INFO_PATH=/home/usebws/apiws-data/auth_info_baileys
MEDIA_PATH=/home/usebws/apiws-data/media
LOGS_PATH=/home/usebws/apiws-data/logs
DATABASE_PATH=/home/usebws/apiws-data/database
TMP_PATH=/home/usebws/apiws-data/tmp

# ==========================================
# Cleanup & Storage Management
# ==========================================
CLEANUP_ENABLED=true
CLEANUP_INTERVAL_HOURS=24
CLEANUP_MEDIA_MAX_AGE_DAYS=30
CLEANUP_LOGS_MAX_AGE_DAYS=30

# ==========================================
# Advanced Limits
# ==========================================
MAX_SESSIONS=5
SESSION_TIMEOUT_HOURS=24
MAINTENANCE_MODE=false

# ==========================================
# External Integration
# ==========================================
ALLOWED_ORIGINS=https://api.useb.ws
GATEWAY_API_URL=
GATEWAY_API_KEY=

# Note on Generating Secure Keys:
# You can generate secure keys for MASTER_API_KEY, TOKEN_ENCRYPTION_KEY, etc.
# by running the following command in your terminal using Node crypto:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
